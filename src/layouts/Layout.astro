---
import '../styles/global.css';
import { colors, fonts, logo } from '../config/theme.mjs';
import site from '../content/settings/site.json';
const { ctaLabel, nav, contact, footerTagline, footerPages, footerLinks, footerBottomLinks, copyright } = site;
const contactIcons: Record<string, string> = { phone: 'call', whatsapp: 'chat', email: 'mail', web: 'language', hours: 'schedule', location: 'location_on' };
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Súmate Digital — Soluciones digitales de alto rendimiento para empresas que quieren dominar su mercado.' } = Astro.props;

// --- Tema → variables CSS que consume global.css (única fuente: src/config/theme.mjs) ---
const hexToRgb = (hex: string) => {
  const h = hex.replace('#', '');
  const n = parseInt(h.length === 3 ? h.split('').map(c => c + c).join('') : h, 16);
  return `${(n >> 16) & 255}, ${(n >> 8) & 255}, ${n & 255}`;
};
const accentRgb = hexToRgb(colors.accent);
const cssVars: Record<string, string> = {
  '--bg-void': colors['bg-void'],
  '--bg-depth': colors['bg-depth'],
  '--accent': colors.accent,
  '--accent-2': colors['accent-2'],
  '--text-primary': colors['text-primary'],
  '--text-secondary': colors['text-secondary'],
  '--text-dim': colors['text-dim'],
  '--grad-indigo': colors['grad-indigo'],
  '--grad-violet': colors['grad-violet'],
  '--grad-pink': colors['grad-pink'],
  '--accent-rgb': accentRgb,
  '--accent-2-rgb': hexToRgb(colors['accent-2']),
  '--accent-dim': `rgba(${accentRgb}, 0.08)`,
  '--accent-glow': `0 0 40px rgba(${accentRgb}, 0.30)`,
  '--accent-glow-strong': `0 0 80px rgba(${accentRgb}, 0.45)`,
  '--glass-border-accent': `rgba(${accentRgb}, 0.28)`,
  '--font-display': fonts.display,
  '--font-body': fonts.body,
};
const rootStyle = ':root{' + Object.entries(cssVars).map(([k, v]) => `${k}:${v}`).join(';') + '}';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" href="/logo-sumate-digital.png" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href={fonts.googleHref} rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
  <style set:html={rootStyle}></style>
</head>
<body class="noise-overlay">

  <!-- NAV -->
  <header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="flex items-center justify-between h-20 transition-all duration-300" id="nav-inner">
        <!-- Logo -->
        <a href="/" class="flex items-center group">
          {logo.image
            ? <span class="inline-flex items-center bg-white rounded-lg px-2.5 py-1.5 shadow-sm">
                <img src={logo.image} alt={logo.alt} class="h-7 md:h-8 w-auto" />
              </span>
            : <span class="inline-flex w-8 h-8 rounded-lg bg-gradient-to-br from-accent to-accent-2 items-center justify-center">
                <span class="material-symbols-outlined text-bg-void text-base" style="font-variation-settings:'wght' 700;">{logo.icon}</span>
              </span>
          }
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-8">
          {nav.map(item => (
            <a href={item.href} class="text-label-sm text-text-secondary hover:text-text-primary transition-colors duration-200 uppercase tracking-widest">{item.label}</a>
          ))}
        </nav>

        <!-- CTA + Mobile toggle -->
        <div class="flex items-center gap-4">
          <a href="/contacto" class="hidden md:inline-flex btn-cyber press">
            <span class="icon-wrap">{ctaLabel} <span class="material-symbols-outlined text-base">arrow_forward</span></span>
          </a>
          <button id="menu-btn" class="md:hidden glass p-2 rounded-lg" aria-label="Menú">
            <span class="material-symbols-outlined text-text-primary">menu</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden glass mx-4 mb-4 rounded-2xl overflow-hidden">
      <nav class="flex flex-col p-4 gap-1">
        {nav.map(item => (
          <a href={item.href} class="px-4 py-3 text-text-secondary hover:text-accent rounded-lg transition-all text-sm font-display font-semibold uppercase tracking-widest">{item.label}</a>
        ))}
        <div class="pt-2 mt-1 border-t border-[rgba(255,255,255,0.07)]">
          <a href="/contacto" class="btn-cyber-solid w-full justify-center text-center block">{ctaLabel}</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="mesh-bg-alt lumen-border mt-0">
    <div class="max-w-container-max mx-auto px-gutter py-section-py-sm">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-16">
        <!-- Brand -->
        <div>
          <a href="/" class="inline-flex items-center mb-4">
            {logo.image
              ? <span class="inline-flex items-center bg-white rounded-lg px-2.5 py-1.5 shadow-sm">
                  <img src={logo.image} alt={logo.alt} class="h-8 w-auto" />
                </span>
              : <span class="inline-flex w-8 h-8 rounded-lg bg-gradient-to-br from-accent to-accent-2 items-center justify-center">
                  <span class="material-symbols-outlined text-bg-void text-base" style="font-variation-settings:'wght' 700;">{logo.icon}</span>
                </span>
            }
          </a>
          <p class="text-text-secondary text-sm leading-relaxed">{footerTagline}</p>
        </div>

        <!-- Contact -->
        <div>
          <p class="tag-cyber mb-5">Contacto</p>
          <ul class="space-y-3">
            {Object.entries(contact).map(([key, value]) => (
              <li class="flex items-center gap-3 text-text-secondary text-sm">
                <span class="material-symbols-outlined text-accent text-base">{contactIcons[key] ?? 'circle'}</span>
                {value}
              </li>
            ))}
          </ul>
        </div>

        <!-- Pages -->
        <div>
          <p class="tag-cyber mb-5">Páginas</p>
          <ul class="space-y-2">
            {footerPages.map(item => (
              <li><a href={item.href} class="text-text-secondary text-sm hover:text-accent transition-colors duration-200">{item.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Quick links -->
        <div>
          <p class="tag-cyber mb-5">Enlaces</p>
          <ul class="space-y-2">
            {footerLinks.map(item => (
              <li><a href={item.href} class="text-text-secondary text-sm hover:text-accent transition-colors duration-200">{item.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <div class="cyber-divider mb-8"></div>
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-text-dim text-sm">{copyright}</p>
        <div class="flex gap-6">
          {footerBottomLinks.map(item => (
            <a href={item.href} class="text-text-dim text-sm hover:text-text-secondary transition-colors">{item.label}</a>
          ))}
        </div>
      </div>
    </div>
  </footer>

</body>
</html>

<script>
  // ---- Scroll: sticky nav glassify ----
  const nav = document.getElementById('site-nav');
  const navInner = document.getElementById('nav-inner');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav!.style.cssText = 'background:rgba(3,3,15,0.80);backdrop-filter:blur(24px) saturate(180%);-webkit-backdrop-filter:blur(24px) saturate(180%);border-bottom:1px solid rgba(255,255,255,0.07);';
      navInner!.style.height = '64px';
    } else {
      nav!.style.cssText = '';
      navInner!.style.height = '80px';
    }
  }, { passive: true });

  // ---- Mobile menu ----
  document.getElementById('menu-btn')?.addEventListener('click', () => {
    const m = document.getElementById('mobile-menu');
    m?.classList.toggle('hidden');
  });

  // ---- IntersectionObserver: reveal + stagger-fade ----
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal, .stagger-fade').forEach(el => io.observe(el));

  // ---- Magnetic buttons ----
  document.querySelectorAll('.magnetic').forEach(el => {
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const r = (el as HTMLElement).getBoundingClientRect();
      const x = (e.clientX - r.left - r.width / 2) * 0.35;
      const y = (e.clientY - r.top - r.height / 2) * 0.35;
      (el as HTMLElement).style.transform = `translate(${x}px,${y}px)`;
    });
    el.addEventListener('mouseleave', () => { (el as HTMLElement).style.transform = ''; });
  });
</script>
