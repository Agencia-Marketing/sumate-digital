---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { highlightHeading } from '../../lib/highlight';

export const prerender = true;

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map(entry => ({
    params: { slug: entry.id },
    props: { s: entry.data },
  }));
}

const { s } = Astro.props;
---
<Layout title={`${s.title} | Súmate Digital`}>
  <section class="mesh-bg relative pt-32 pb-section-py-sm overflow-hidden">
    <div class="absolute top-1/3 right-1/4 w-80 h-80 rounded-full bg-accent/5 blur-[120px] pointer-events-none"></div>
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <span class="tag-cyber mb-5 inline-flex"><span class="material-symbols-outlined text-sm">{s.icon}</span>{s.title}</span>
          <h1 class="font-display text-display-hero-mobile md:text-5xl font-extrabold mb-5" set:html={highlightHeading(s.heroHeading, s.heroHighlight)}></h1>
          <p class="text-body-lg text-text-secondary mb-8">{s.heroSub}</p>
          <div class="flex gap-4 flex-wrap">
            <a href="/contacto" class="btn-cyber-solid magnetic press">{s.heroCtaLabel}</a>
            <a href="#planes" class="btn-ghost magnetic press">Ver planes</a>
          </div>
        </div>
        <div class="reveal">
          <div class="glass card-cyber rounded-2xl overflow-hidden animate-float">
            <img src={s.image} alt={s.imageAlt} class="w-full aspect-video object-cover opacity-80" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-bg-depth py-14">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-3 gap-5 stagger-fade">
        {s.features.map(f => (
          <div class="glass card-cyber rounded-2xl p-7">
            <div class="w-12 h-12 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center mb-4">
              <span class="material-symbols-outlined text-accent text-2xl">{f.icon}</span>
            </div>
            <h3 class="font-display font-bold text-lg mb-2">{f.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="planes" class="mesh-bg py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-14 reveal">
        <span class="tag-cyber mb-4 inline-flex">Planes</span>
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg">Nuestros <span class="gradient-text">planes</span></h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 stagger-fade">
        {s.plans.map(p => (
          <div class={`glass card-cyber rounded-2xl p-7 flex flex-col ${p.featured ? 'lumen-border scale-105 relative' : ''}`}>
            {p.featured && <span class="tag-cyber mb-4 self-start">Más Popular</span>}
            <p class="font-display font-bold text-xl mb-1">{p.name}</p>
            <p class="text-text-secondary text-sm mb-5">{p.sub}</p>
            <ul class="space-y-2 mb-6 flex-1">
              {p.features.map(f => (
                <li class="flex items-start gap-2 text-sm text-text-secondary">
                  <span class="material-symbols-outlined text-accent text-base mt-0.5 flex-shrink-0">check_circle</span>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contacto" class={p.featured ? 'btn-cyber-solid w-full justify-center text-center' : 'btn-ghost w-full justify-center text-center'}>Cotizar</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bg-depth py-section-py-sm">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="glass lumen-border rounded-3xl p-12 text-center reveal" style="background: linear-gradient(135deg, rgba(18,61,137,0.10) 0%, rgba(252,163,17,0.05) 100%);">
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg mb-4">{s.ctaHeading}</h2>
        <p class="text-text-secondary mb-8 max-w-xl mx-auto">{s.ctaText}</p>
        <a href="/contacto" class="btn-cyber-solid magnetic press inline-flex">
          <span class="icon-wrap">{s.ctaButtonLabel} <span class="material-symbols-outlined text-base">{s.ctaButtonIcon}</span></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
