---
import Layout from '../../layouts/Layout.astro';
import s from '../../content/services-custom/agentes-ia.json';
import { highlightHeading } from '../../lib/highlight';

export const prerender = true;
---
<Layout title={`${s.title} | Súmate Digital`}>
  <section class="mesh-bg relative pt-32 pb-section-py-sm overflow-hidden">
    <div class="absolute top-1/4 right-1/3 w-80 h-80 rounded-full bg-accent/5 blur-[120px] pointer-events-none"></div>
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <span class="tag-cyber mb-5 inline-flex"><span class="material-symbols-outlined text-sm">{s.heroTagIcon}</span>{s.title}</span>
          <h1 class="font-display text-display-hero-mobile md:text-5xl font-extrabold mb-5" set:html={highlightHeading(s.heroHeading, s.heroHighlight)}></h1>
          <p class="text-body-lg text-text-secondary mb-8">{s.heroSub}</p>
          <div class="flex gap-4 flex-wrap">
            <a href="/contacto" class="btn-cyber-solid magnetic press">Solicitar servicio</a>
            <a href="#planes" class="btn-ghost magnetic press">Ver planes</a>
          </div>
        </div>
        <div class="reveal">
          <div class="glass card-cyber rounded-2xl overflow-hidden animate-float">
            <img src={s.image} alt={s.imageAlt} class="w-full aspect-video object-cover opacity-80" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-bg-depth py-14">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-3 gap-5 stagger-fade">
        {s.features.map(f => (
          <div class="glass card-cyber rounded-2xl p-7">
            <div class="w-12 h-12 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center mb-4">
              <span class="material-symbols-outlined text-accent text-2xl">{f.icon}</span>
            </div>
            <h3 class="font-display font-bold text-lg mb-2">{f.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mesh-bg py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-14 reveal">
        <span class="tag-cyber mb-4 inline-flex">Comparativa</span>
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg mb-2" set:html={highlightHeading(s.comparisonHeading, s.comparisonHighlight)}></h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 reveal">
        <div class="glass card-cyber rounded-2xl p-8">
          <p class="font-display font-bold text-lg mb-5 text-text-secondary">{s.compareLeftTitle}</p>
          <ul class="space-y-3">
            {s.comparisonLeft.map(item => (
              <li class="flex items-center gap-3 text-text-secondary text-sm">
                <span class="material-symbols-outlined text-red-400 text-base">cancel</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="glass lumen-border card-cyber rounded-2xl p-8" style="background: linear-gradient(135deg, rgba(22,79,157,0.06) 0%, rgba(18,61,137,0.08) 100%);">
          <p class="font-display font-bold text-lg mb-5 text-accent">{s.compareRightTitle}</p>
          <ul class="space-y-3">
            {s.comparisonRight.map(item => (
              <li class="flex items-center gap-3 text-text-primary text-sm">
                <span class="material-symbols-outlined text-accent text-base">check_circle</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="planes" class="bg-bg-depth py-section-py-sm">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-14 reveal">
        <span class="tag-cyber mb-4 inline-flex">Plan</span>
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg">Nuestro <span class="gradient-text">plan</span></h2>
      </div>
      <div class="max-w-lg mx-auto reveal">
        <div class="glass lumen-border card-cyber rounded-2xl p-10 text-center" style="background: linear-gradient(135deg, rgba(22,79,157,0.06) 0%, rgba(18,61,137,0.08) 100%);">
          <span class="tag-cyber mb-4 inline-flex">{s.plan.badge}</span>
          <p class="text-text-secondary mt-4 mb-6">{s.plan.note}</p>
          <ul class="space-y-3 mb-8 text-left">
            {s.plan.features.map(f => (
              <li class="flex items-center gap-3 text-sm text-text-secondary">
                <span class="material-symbols-outlined text-accent text-base">check_circle</span>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contacto" class="btn-cyber-solid w-full justify-center magnetic press">{s.plan.buttonLabel}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="mesh-bg py-section-py-sm">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="glass lumen-border rounded-3xl p-12 text-center reveal" style="background: linear-gradient(135deg, rgba(18,61,137,0.10) 0%, rgba(22,79,157,0.05) 100%);">
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg mb-4">{s.ctaHeading}</h2>
        <p class="text-text-secondary mb-8 max-w-xl mx-auto">{s.ctaText}</p>
        <a href="/contacto" class="btn-cyber-solid magnetic press inline-flex">
          <span class="icon-wrap">{s.ctaButtonLabel} <span class="material-symbols-outlined text-base">{s.ctaButtonIcon}</span></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
