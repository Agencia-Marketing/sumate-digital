---
import Layout from '../layouts/Layout.astro';
import about from '../content/pages/about.json';
import { highlightHeading } from '../lib/highlight';

export const prerender = true;
---
<Layout title={about.title}>

  <!-- HERO -->
  <section class="mesh-bg relative pt-32 pb-section-py-sm overflow-hidden">
    <div class="absolute top-1/3 left-1/3 w-80 h-80 rounded-full bg-accent/5 blur-[120px] pointer-events-none"></div>
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <span class="tag-cyber mb-5 inline-flex"><span class="material-symbols-outlined text-sm">groups</span>{about.heroTag}</span>
          <h1 class="font-display text-display-hero-mobile md:text-5xl font-extrabold mb-5" set:html={highlightHeading(about.heroHeading, about.heroHighlight)}></h1>
          <p class="text-body-lg text-text-secondary mb-8">
            {about.heroParagraph}
          </p>
          <div class="flex gap-4 flex-wrap">
            <a href={about.heroCtaPrimary.href} class="btn-cyber-solid magnetic press">{about.heroCtaPrimary.label}</a>
            <a href={about.heroCtaSecondary.href} class="btn-ghost magnetic press">{about.heroCtaSecondary.label}</a>
          </div>
        </div>
        <div class="reveal">
          <div class="glass card-cyber rounded-2xl overflow-hidden animate-float">
            <img
              src={about.heroImage}
              alt={about.heroImageAlt}
              class="w-full aspect-[4/3] object-cover opacity-85"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="historia" class="bg-bg-depth py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-12 gap-10 items-center">
        <!-- Image col -->
        <div class="md:col-span-5 reveal">
          <div class="relative">
            <div class="glass card-cyber rounded-2xl overflow-hidden">
              <img
                src={about.aboutImage}
                alt={about.aboutImageAlt}
                class="w-full aspect-square object-cover opacity-80"
              />
            </div>
            <div class="absolute -bottom-4 -right-4 glass rounded-xl px-5 py-3 border border-accent/30">
              <p class="text-accent font-display font-bold text-sm">{about.aboutBadgeValue}</p>
              <p class="text-text-secondary text-xs">{about.aboutBadgeLabel}</p>
            </div>
          </div>
        </div>
        <!-- Content col -->
        <div class="md:col-span-7 reveal">
          <span class="tag-cyber mb-5 inline-flex">{about.aboutTag}</span>
          <h2 class="font-display text-headline-lg-mobile md:text-headline-lg mb-5" set:html={highlightHeading(about.aboutHeading, about.aboutHighlight)}></h2>
          {about.aboutParagraphs.map(p => (
            <p class="text-body-md text-text-secondary mb-6 leading-relaxed">{p}</p>
          ))}
          <a href="/contacto" class="btn-cyber-solid magnetic press inline-flex">
            <span class="icon-wrap">{about.aboutCtaLabel} <span class="material-symbols-outlined text-base">arrow_forward</span></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="mesh-bg py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-14 reveal">
        <span class="tag-cyber mb-4 inline-flex">{about.statsTag}</span>
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg mb-5" set:html={highlightHeading(about.statsHeading, about.statsHighlight)}></h2>
        <p class="text-body-md text-text-secondary max-w-2xl mx-auto">
          {about.statsParagraph}
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-5 stagger-fade">
        {about.stats.map(s => (
          <div class="glass card-cyber rounded-2xl p-8 text-center">
            <p class="font-display font-extrabold text-4xl gradient-text mb-2">{s.value}</p>
            <p class="text-text-secondary text-sm">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="bg-bg-depth py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-14 reveal">
        <span class="tag-cyber mb-4 inline-flex">{about.teamTag}</span>
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg mb-4" set:html={highlightHeading(about.teamHeading, about.teamHighlight)}></h2>
        <p class="text-text-secondary text-body-md italic mb-6">"{about.teamQuote}"</p>
        <a href="/contacto" class="btn-cyber magnetic press inline-flex">
          <span class="icon-wrap">{about.teamCtaLabel} <span class="material-symbols-outlined text-base">calendar_month</span></span>
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 stagger-fade">
        {about.team.map(m => (
          <div class="glass card-cyber rounded-2xl overflow-hidden group">
            <div class="overflow-hidden">
              <img
                src={m.img}
                alt={m.name}
                class="w-full aspect-square object-cover grayscale group-hover:grayscale-0 transition-all duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-5">
              <p class="font-display font-bold text-text-primary">{m.name}</p>
              <p class="text-accent text-sm mt-1">{m.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
